generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// IDENTIDAD Y ACCESOS
// ============================================

model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  nombre      String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  logoUrl     String?  @map("logo_url")
  plan        String   @default("basico") @db.VarChar(50)
  config      Json     @default("{}")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sucursales   Sucursal[]
  usuarios     Usuario[]
  roles        Rol[]
  clientes     Cliente[]
  proveedores  Proveedor[]

  @@map("tenants")
}

model Sucursal {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  nombre     String   @db.VarChar(255)
  direccion  String?
  telefono   String?  @db.VarChar(50)
  email      String?  @db.VarChar(255)
  horario    Json?
  activa     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  sectores     Sector[]
  mesas        Mesa[]
  pedidos      Pedido[]
  reservas     Reserva[]
  stock        StockPorSucursal[]
  ordenesCompra OrdenCompra[]
  equipos      Equipo[]
  asistencias  Asistencia[]
  visitasMesas VisitaMesa[]

  @@index([tenantId])
  @@map("sucursales")
}

model Usuario {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  email           String    @db.VarChar(255)
  nombre          String    @db.VarChar(255)
  telefono        String?   @db.VarChar(50)
  avatarUrl       String?   @map("avatar_url")
  passwordHash    String    @map("password_hash")
  emailVerificado Boolean   @default(false) @map("email_verificado")
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  usuarioRoles   UsuarioRol[]
  sesiones       Sesion[]
  pedidosMozo    Pedido[]        @relation("MozoPedidos")
  pedidosCreados Pedido[]        @relation("CreadorPedidos")
  auditLogs      AuditLog[]
  empleados      Empleado[]
  notificaciones Notificacion[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("usuarios")
}

model Rol {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  nombre     String   @db.VarChar(100)
  descripcion String?
  permisos   Json     @default("[]")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  usuarioRoles UsuarioRol[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("roles")
}

model UsuarioRol {
  id         String   @id @default(uuid()) @db.Uuid
  usuarioId  String   @map("usuario_id") @db.Uuid
  rolId      String   @map("rol_id") @db.Uuid
  sucursalId String?  @map("sucursal_id") @db.Uuid

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  rol     Rol     @relation(fields: [rolId], references: [id])

  @@unique([usuarioId, rolId, sucursalId])
  @@map("usuario_roles")
}

model Sesion {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiraEn  DateTime @map("expira_en")
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@map("sesiones")
}

// ============================================
// SALON Y MESAS
// ============================================

model Sector {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  sucursalId String   @map("sucursal_id") @db.Uuid
  nombre     String   @db.VarChar(100)
  tipo       String?  @db.VarChar(50)
  orden      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])
  mesas    Mesa[]

  @@index([tenantId, sucursalId])
  @@map("sectores")
}

model Mesa {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  sucursalId String   @map("sucursal_id") @db.Uuid
  sectorId   String   @map("sector_id") @db.Uuid
  numero     String   @db.VarChar(10)
  capacidad  Int      @default(4)
  estado     String   @default("libre") @db.VarChar(50)
  posicionX  Float?   @map("posicion_x")
  posicionY  Float?   @map("posicion_y")
  qrCode     String?  @unique @map("qr_code")
  activa     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])
  sector   Sector   @relation(fields: [sectorId], references: [id])
  pedidos  Pedido[]
  reservas Reserva[]
  visitasMesas VisitaMesa[]

  @@index([tenantId, sucursalId, estado])
  @@map("mesas")
}

// ============================================
// MENU Y RECETAS
// ============================================

model CategoriaMenu {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  nombre     String   @db.VarChar(100)
  descripcion String?
  imagenUrl  String?  @map("imagen_url")
  orden      Int      @default(0)
  activa     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  productos Producto[]

  @@index([tenantId])
  @@map("categorias_menu")
}

model Producto {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  categoriaId         String   @map("categoria_id") @db.Uuid
  nombre              String   @db.VarChar(255)
  descripcion         String?
  precio              Decimal  @db.Decimal(10, 2)
  costo               Decimal? @db.Decimal(10, 2)
  margen              Decimal? @db.Decimal(5, 2)
  imagenUrl           String?  @map("imagen_url")
  videoUrl            String?  @map("video_url")
  tiempoPreparacionMin Int?    @map("tiempo_preparacion_min")
  nivelPicante        Int      @default(0)
  calorias            Int?
  proteinas           Decimal? @db.Decimal(5, 2)
  grasas              Decimal? @db.Decimal(5, 2)
  carbohidratos       Decimal? @db.Decimal(5, 2)
  alergenos           String[] @default([])
  disponible          Boolean  @default(true)
  destacado           Boolean  @default(false)
  tipo                String   @default("plato") @db.VarChar(50)
  estacion            String?  @db.VarChar(50)
  idiomas             Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  categoria        CategoriaMenu      @relation(fields: [categoriaId], references: [id])
  recetas          Receta[]
  pedidoItems      PedidoItem[]
  clienteFavoritos ClienteFavorito[]

  @@index([tenantId, categoriaId])
  @@index([tenantId, disponible])
  @@map("productos")
}

model Ingrediente {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  nombre        String   @db.VarChar(255)
  unidadMedida  String   @map("unidad_medida") @db.VarChar(50)
  costoUnitario Decimal? @map("costo_unitario") @db.Decimal(10, 4)
  proveedorId   String?  @map("proveedor_id") @db.Uuid
  stockMinimo   Decimal? @map("stock_minimo") @db.Decimal(10, 2)
  stockMaximo   Decimal? @map("stock_maximo") @db.Decimal(10, 2)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  recetaIngredientes  RecetaIngrediente[]
  stockPorSucursal    StockPorSucursal[]
  stockMovimientos    StockMovimiento[]
  proveedorProducto   ProveedorProducto[]
  ordenesCompraItems  OrdenCompraItem[]

  @@index([tenantId])
  @@map("ingredientes")
}

model Receta {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  productoId  String   @map("producto_id") @db.Uuid
  nombre      String?  @db.VarChar(255)
  porciones   Int      @default(1)
  instrucciones String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  producto          Producto          @relation(fields: [productoId], references: [id])
  recetaIngredientes RecetaIngrediente[]

  @@unique([tenantId, productoId])
  @@map("recetas")
}

model RecetaIngrediente {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  recetaId       String  @map("receta_id") @db.Uuid
  ingredienteId  String  @map("ingrediente_id") @db.Uuid
  cantidad       Decimal @db.Decimal(10, 3)
  unidad         String  @db.VarChar(50)
  opcional       Boolean @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  receta      Receta      @relation(fields: [recetaId], references: [id])
  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@unique([recetaId, ingredienteId])
  @@map("receta_ingredientes")
}

// ============================================
// PEDIDOS Y COCINA
// ============================================

model Pedido {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  sucursalId  String   @map("sucursal_id") @db.Uuid
  mesaId      String?  @map("mesa_id") @db.Uuid
  clienteId   String?  @map("cliente_id") @db.Uuid
  mozoId      String?  @map("mozo_id") @db.Uuid
  creadoPorId String?  @map("creado_por_id") @db.Uuid
  estado      String   @default("recibido") @db.VarChar(50)
  tipo        String   @default("mesa") @db.VarChar(50)
  horaProgramada DateTime? @map("hora_programada")
  notas       String?
  total       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sucursal    Sucursal    @relation(fields: [sucursalId], references: [id])
  mesa        Mesa?       @relation(fields: [mesaId], references: [id])
  cliente     Cliente?    @relation(fields: [clienteId], references: [id])
  mozo        Usuario?    @relation("MozoPedidos", fields: [mozoId], references: [id])
  creador     Usuario?    @relation("CreadorPedidos", fields: [creadoPorId], references: [id])
  items       PedidoItem[]
  eventos     PedidoEvento[]
  pagos       Pago[]
  asignacionesReparto AsignacionReparto[]
  feedbacks   Feedback[]

  @@index([tenantId, sucursalId, estado])
  @@index([tenantId, mesaId])
  @@map("pedidos")
}

model PedidoItem {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  pedidoId       String   @map("pedido_id") @db.Uuid
  productoId     String   @map("producto_id") @db.Uuid
  cantidad       Int      @default(1)
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  notas          String?
  estado         String   @default("recibido") @db.VarChar(50)
  horaEnviado    DateTime? @map("hora_enviado")
  horaListo      DateTime? @map("hora_listo")
  horaEntregado  DateTime? @map("hora_entregado")
  anulado        Boolean  @default(false)
  urgente        Boolean  @default(false)
  motivoAnulacion String? @map("motivo_anulacion")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  pedido   Pedido   @relation(fields: [pedidoId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
  eventos  PedidoEvento[]
  anulaciones Anulacion[]

  @@index([pedidoId])
  @@map("pedido_items")
}

model PedidoEvento {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  pedidoId     String   @map("pedido_id") @db.Uuid
  pedidoItemId String?  @map("pedido_item_id") @db.Uuid
  evento       String   @db.VarChar(100)
  usuarioId    String?  @map("usuario_id") @db.Uuid
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  pedido     Pedido      @relation(fields: [pedidoId], references: [id])
  pedidoItem PedidoItem? @relation(fields: [pedidoItemId], references: [id])

  @@index([pedidoId, createdAt])
  @@map("pedido_eventos")
}

// ============================================
// RESERVAS
// ============================================

model Reserva {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  sucursalId        String   @map("sucursal_id") @db.Uuid
  mesaId            String?  @map("mesa_id") @db.Uuid
  clienteId         String?  @map("cliente_id") @db.Uuid
  fecha             DateTime @db.Date
  hora              DateTime @db.Time
  cantidadPersonas  Int      @map("cantidad_personas")
  zona              String?  @db.VarChar(50)
  occasion          String?  @db.VarChar(100)
  notas             String?
  estado            String   @default("pendiente") @db.VarChar(50)
  recordatorioEnviado Boolean @default(false) @map("recordatorio_enviado")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])
  mesa     Mesa?    @relation(fields: [mesaId], references: [id])
  cliente  Cliente? @relation(fields: [clienteId], references: [id])

  @@index([tenantId, sucursalId, fecha])
  @@map("reservas")
}

// ============================================
// CAJA Y PAGOS
// ============================================

model Caja {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  sucursalId   String    @map("sucursal_id") @db.Uuid
  cajeroId     String    @map("cajero_id") @db.Uuid
  montoInicial Decimal   @map("monto_inicial") @db.Decimal(10, 2)
  montoFinal   Decimal?  @map("monto_final") @db.Decimal(10, 2)
  diferencia   Decimal?  @db.Decimal(10, 2)
  estado       String    @default("abierta") @db.VarChar(50)
  abiertaEn    DateTime  @default(now()) @map("abierta_en")
  cerradaEn    DateTime? @map("cerrada_en")

  pagos Pago[]

  @@index([tenantId, sucursalId, estado])
  @@map("cajas")
}

model Pago {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  pedidoId      String   @map("pedido_id") @db.Uuid
  cajaId        String?  @map("caja_id") @db.Uuid
  monto         Decimal  @db.Decimal(10, 2)
  propina       Decimal  @default(0) @db.Decimal(10, 2)
  metodoPago    String   @map("metodo_pago") @db.VarChar(50)
  estado        String   @default("completado") @db.VarChar(50)
  comprobanteUrl String? @map("comprobante_url")
  usuarioId     String?  @map("usuario_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  pedido Pedido @relation(fields: [pedidoId], references: [id])
  caja   Caja?  @relation(fields: [cajaId], references: [id])

  @@index([tenantId, pedidoId])
  @@map("pagos")
}

// ============================================
// RRHH
// ============================================

model Empleado {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  usuarioId     String   @map("usuario_id") @db.Uuid
  sucursalId    String   @map("sucursal_id") @db.Uuid
  cargo         String?  @db.VarChar(100)
  fechaIngreso  DateTime? @map("fecha_ingreso")
  salarioBase   Decimal? @map("salario_base") @db.Decimal(10, 2)
  tipoContrato  String?  @map("tipo_contrato") @db.VarChar(50)
  estado        String   @default("activo") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  turnos   Turno[]
  asistencia Asistencia[]
  asignacionesReparto AsignacionReparto[]

  @@index([tenantId, sucursalId])
  @@map("empleados")
}

model Turno {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  empleadoId  String   @map("empleado_id") @db.Uuid
  sucursalId  String   @map("sucursal_id") @db.Uuid
  fecha       DateTime @db.Date
  horaInicio  DateTime @map("hora_inicio") @db.Time
  horaFin     DateTime @map("hora_fin") @db.Time
  estado      String   @default("asignado") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  empleado   Empleado      @relation(fields: [empleadoId], references: [id])
  asistencia Asistencia[]

  @@index([tenantId, empleadoId, fecha])
  @@map("turnos")
}

model Asistencia {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  empleadoId     String    @map("empleado_id") @db.Uuid
  turnoId        String?   @map("turno_id") @db.Uuid
  sucursalId     String?   @map("sucursal_id") @db.Uuid
  tipo           String?   @map("tipo") @db.VarChar(20) // ENTRADA | SALIDA | BREAK_IN | BREAK_OUT
  entrada        DateTime?
  salida         DateTime?
  breakInicio    DateTime? @map("break_inicio")
  breakFin      DateTime? @map("break_fin")
  horasTrabajadas Decimal? @map("horas_trabajadas") @db.Decimal(5, 2)
  createdAt      DateTime  @default(now()) @map("created_at")

  empleado  Empleado  @relation(fields: [empleadoId], references: [id])
  turno     Turno?    @relation(fields: [turnoId], references: [id])
  sucursal  Sucursal? @relation(fields: [sucursalId], references: [id])

  @@index([tenantId, empleadoId])
  @@map("asistencia")
}

// ============================================
// CLIENTES Y CRM
// ============================================

model Cliente {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  nombre          String    @db.VarChar(255)
  email           String?   @db.VarChar(255)
  telefono        String?   @db.VarChar(50)
  fechaNacimiento DateTime? @map("fecha_nacimiento")
  alergias        String[]  @default([])
  dieta           String?   @db.VarChar(100)
  preferencias    Json      @default("{}")
  puntos          Int       @default(0)
  nivel           String    @default("bronce") @db.VarChar(50)
  totalGastado    Decimal   @default(0) @map("total_gastado") @db.Decimal(10, 2)
  totalVisitas    Int       @default(0) @map("total_visitas")
  ultimaVisita    DateTime? @map("ultima_visita")
  optInMarketing  Boolean   @default(false) @map("opt_in_marketing")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  pedidos         Pedido[]
  reservas        Reserva[]
  favoritos       ClienteFavorito[]
  puntosHistorial PuntosHistorial[]
  visitasMesas    VisitaMesa[]

  @@index([tenantId])
  @@map("clientes")
}

model ClienteFavorito {
  id         String   @id @default(uuid()) @db.Uuid
  clienteId  String   @map("cliente_id") @db.Uuid
  productoId String   @map("producto_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  cliente  Cliente  @relation(fields: [clienteId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([clienteId, productoId])
  @@map("cliente_favoritos")
}

// ============================================
// INVENTARIO Y COMPRAS
// ============================================

model Proveedor {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  nombre           String   @db.VarChar(255)
  contactoNombre   String?  @map("contacto_nombre")
  contactoEmail    String?  @map("contacto_email")
  contactoTelefono String?  @map("contacto_telefono") @db.VarChar(50)
  direccion        String?
  tiempoEntregaDias Int?   @map("tiempo_entrega_dias")
  calificacion     Decimal? @db.Decimal(3, 2)
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  productoProveedor ProveedorProducto[]
  ordenesCompra    OrdenCompra[]

  @@index([tenantId])
  @@map("proveedores")
}

model ProveedorProducto {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  proveedorId   String  @map("proveedor_id") @db.Uuid
  ingredienteId String  @map("ingrediente_id") @db.Uuid
  precio        Decimal @db.Decimal(10, 4)
  unidad        String  @db.VarChar(50)
  tiempoEntregaDias Int? @map("tiempo_entrega_dias")
  createdAt     DateTime @default(now()) @map("created_at")

  proveedor   Proveedor   @relation(fields: [proveedorId], references: [id])
  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@unique([proveedorId, ingredienteId])
  @@map("proveedor_producto")
}

model StockPorSucursal {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  sucursalId      String   @map("sucursal_id") @db.Uuid
  ingredienteId   String   @map("ingrediente_id") @db.Uuid
  cantidadActual  Decimal  @map("cantidad_actual") @db.Decimal(10, 3)
  cantidadReservada Decimal @default(0) @map("cantidad_reservada") @db.Decimal(10, 3)
  lote            String?  @db.VarChar(100)
  fechaVencimiento DateTime? @map("fecha_vencimiento")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  sucursal    Sucursal    @relation(fields: [sucursalId], references: [id])
  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@unique([sucursalId, ingredienteId, lote])
  @@map("stock_por_sucursal")
}

model StockMovimiento {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  sucursalId    String   @map("sucursal_id") @db.Uuid
  ingredienteId String   @map("ingrediente_id") @db.Uuid
  tipo          String   @db.VarChar(50)
  cantidad      Decimal  @db.Decimal(10, 3)
  motivo        String?
  origen        String?  @db.VarChar(50)
  pedidoId      String?  @map("pedido_id") @db.Uuid
  usuarioId     String?  @map("usuario_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@index([tenantId, sucursalId, ingredienteId])
  @@map("stock_movimientos")
}

model OrdenCompra {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  sucursalId  String   @map("sucursal_id") @db.Uuid
  proveedorId String   @map("proveedor_id") @db.Uuid
  estado      String   @default("borrador") @db.VarChar(50)
  total       Decimal? @db.Decimal(10, 2)
  notas       String?
  usuarioId   String?  @map("usuario_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sucursal   Sucursal              @relation(fields: [sucursalId], references: [id])
  proveedor  Proveedor             @relation(fields: [proveedorId], references: [id])
  items      OrdenCompraItem[]

  @@index([tenantId, sucursalId])
  @@map("ordenes_compra")
}

model OrdenCompraItem {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  ordenCompraId   String   @map("orden_compra_id") @db.Uuid
  ingredienteId   String   @map("ingrediente_id") @db.Uuid
  cantidad        Decimal  @db.Decimal(10, 3)
  precioUnitario  Decimal  @map("precio_unitario") @db.Decimal(10, 4)
  subtotal        Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id])
  ingrediente Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@map("ordenes_compra_items")
}

// ============================================
// MARKETING Y FIDELIZACION
// ============================================

model Campana {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  nombre        String   @db.VarChar(100)
  descripcion   String?  @db.Text
  tipo          String   @db.VarChar(50)
  estado        String   @default("borrador") @db.VarChar(50)
  fechaInicio   DateTime @map("fecha_inicio")
  fechaFin      DateTime? @map("fecha_fin")
  publicoObjetivo Json?  @map("publico_objetivo")
  contenido     Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("campanas")
}

model Cupon {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  codigo              String   @unique @db.VarChar(20)
  descripcion         String   @db.VarChar(200)
  tipo                String   @db.VarChar(50)
  valor               Decimal  @db.Decimal(10, 2)
  fechaInicio         DateTime @map("fecha_inicio")
  fechaFin            DateTime @map("fecha_fin")
  usosMaximos         Int      @map("usos_maximos")
  usosActuales        Int      @default(0) @map("usos_actuales")
  usosPorCliente      Int      @default(1) @map("usos_por_cliente")
  minimoCompra        Decimal  @default(0) @map("minimo_compra") @db.Decimal(10, 2)
  productosAplicables String[] @default([]) @map("productos_aplicables")
  categoriasAplicables String[] @default([]) @map("categorias_aplicables")
  activo              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([tenantId, activo])
  @@map("cupones")
}

model PuntosHistorial {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  clienteId  String   @map("cliente_id") @db.Uuid
  tipo       String   @db.VarChar(50)
  puntos     Int
  motivo     String?
  pedidoId   String?  @map("pedido_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@index([tenantId, clienteId])
  @@map("puntos_historial")
}

// ============================================
// NOTIFICACIONES
// ============================================

model Notificacion {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  usuarioId String?  @map("usuario_id") @db.Uuid
  tipo      String   @db.VarChar(50)
  titulo    String   @db.VarChar(200)
  mensaje   String   @db.Text
  leida     Boolean  @default(false)
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([tenantId, usuarioId, leida])
  @@index([tenantId, createdAt])
  @@map("notificaciones")
}

// ============================================
// AUDITORIA
// ============================================

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  usuarioId     String?  @map("usuario_id") @db.Uuid
  accion        String   @db.VarChar(100)
  entidad       String   @db.VarChar(100)
  entidadId     String?  @map("entidad_id") @db.Uuid
  valorAnterior Json?    @map("valor_anterior")
  valorNuevo    Json?    @map("valor_nuevo")
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([tenantId, entidad, entidadId])
  @@index([tenantId, createdAt])
  @@map("audit_log")
}

// ============================================
// BLOQUE 2 — PRODUCTIVIDAD OPERATIVA Y VENTA
// (micro-fases 2.1 a 2.23, ver 07_Productividad/)
// ============================================

// --- 2.4 Fidelización: historial de visitas por mesa ---
model VisitaMesa {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  clienteId  String?  @map("cliente_id") @db.Uuid
  mesaId     String   @map("mesa_id") @db.Uuid
  sucursalId String   @map("sucursal_id") @db.Uuid
  personas   Int?
  monto      Decimal? @db.Decimal(10, 2)
  fecha      DateTime @default(now())

  cliente  Cliente? @relation(fields: [clienteId], references: [id])
  mesa     Mesa    @relation(fields: [mesaId], references: [id])
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@index([tenantId, mesaId])
  @@index([tenantId, clienteId])
  @@map("visitas_mesa")
}

// --- 2.1 Checklist de apertura/cierre + 2.2 fichaje ---
model ChecklistPlantilla {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  sucursalId String?  @map("sucursal_id") @db.Uuid
  tipo       String   @db.VarChar(20) // APERTURA | CIERRE
  nombre     String   @db.VarChar(100)
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  items     ChecklistItem[]
  ejecuciones ChecklistEjecucion[]

  @@index([tenantId, tipo])
  @@map("checklist_plantillas")
}

model ChecklistItem {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  plantillaId  String  @map("plantilla_id") @db.Uuid
  descripcion  String
  obligatorio  Boolean @default(true)
  orden        Int     @default(0)

  plantilla  ChecklistPlantilla     @relation(fields: [plantillaId], references: [id])
  ejecuciones ChecklistEjecucionItem[]

  @@index([plantillaId])
  @@map("checklist_items")
}

model ChecklistEjecucion {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  plantillaId String   @map("plantilla_id") @db.Uuid
  sucursalId  String   @map("sucursal_id") @db.Uuid
  turnoId     String?  @map("turno_id") @db.Uuid
  usuarioId   String   @map("usuario_id") @db.Uuid
  completo    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  plantilla ChecklistPlantilla     @relation(fields: [plantillaId], references: [id])
  items     ChecklistEjecucionItem[]

  @@index([tenantId, sucursalId])
  @@map("checklist_ejecuciones")
}

model ChecklistEjecucionItem {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  ejecucionId    String   @map("ejecucion_id") @db.Uuid
  itemId         String   @map("item_id") @db.Uuid
  valor          String?  // ej. temperatura, monto de caja
  marcado        Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  ejecucion ChecklistEjecucion @relation(fields: [ejecucionId], references: [id])
  item      ChecklistItem       @relation(fields: [itemId], references: [id])

  @@unique([ejecucionId, itemId])
  @@map("checklist_ejecucion_items")
}

// --- 2.2 Anulación trazable ---
model Anulacion {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  pedidoItemId  String   @map("pedido_item_id") @db.Uuid
  usuarioId     String   @map("usuario_id") @db.Uuid
  motivo        String
  motivoLibre   String?  @map("motivo_libre")
  createdAt     DateTime @default(now()) @map("created_at")

  pedidoItem PedidoItem @relation(fields: [pedidoItemId], references: [id])

  @@index([tenantId, pedidoItemId])
  @@map("anulaciones")
}

// --- 2.10 Zonas de reparto + 2.10.1 repartidor ---
model ZonaReparto {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  sucursalId      String   @map("sucursal_id") @db.Uuid
  nombre          String   @db.VarChar(100)
  tiempoEstimadoMin Int    @map("tiempo_estimado_min")
  poligono        Json?
  activa          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tenantId, sucursalId])
  @@map("zonas_reparto")

  asignaciones AsignacionReparto[]
}

model AsignacionReparto {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  pedidoId    String   @map("pedido_id") @db.Uuid
  empleadoId  String   @map("empleado_id") @db.Uuid
  zonaId      String?  @map("zona_id") @db.Uuid
  estado      String   @default("asignado") @db.VarChar(50)
  horaSalida  DateTime? @map("hora_salida")
  horaEntrega DateTime? @map("hora_entrega")
  createdAt   DateTime @default(now()) @map("created_at")

  pedido   Pedido   @relation(fields: [pedidoId], references: [id])
  empleado Empleado @relation(fields: [empleadoId], references: [id])
  zona     ZonaReparto? @relation(fields: [zonaId], references: [id])

  @@index([tenantId, empleadoId, estado])
  @@map("asignaciones_reparto")
}

// --- 2.13 Mantenimiento de equipos ---
model Equipo {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  sucursalId      String   @map("sucursal_id") @db.Uuid
  nombre          String   @db.VarChar(100)
  tipo            String?  @db.VarChar(50) // HORNO | HELADERA | FREEZER
  ubicacion       String?
  frecuenciaMantenimientoDias Int? @map("frecuencia_mantenimiento_dias")
  ultimaIntervencion DateTime? @map("ultima_intervencion")
  proximaIntervencion DateTime? @map("proxima_intervencion")
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  sucursal      Sucursal            @relation(fields: [sucursalId], references: [id])
  temperaturas  RegistroTemperatura[]
  intervenciones EquipoIntervencion[]

  @@index([tenantId, sucursalId])
  @@map("equipos")
}

model RegistroTemperatura {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  equipoId   String   @map("equipo_id") @db.Uuid
  sucursalId String   @map("sucursal_id") @db.Uuid
  temperatura Decimal @db.Decimal(5, 2)
  rangoMin    Decimal? @map("rango_min") @db.Decimal(5, 2)
  rangoMax    Decimal? @map("rango_max") @db.Decimal(5, 2)
  fueraDeRango Boolean @default(false) @map("fuera_de_rango")
  usuarioId  String?  @map("usuario_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  equipo Equipo @relation(fields: [equipoId], references: [id])

  @@index([tenantId, equipoId, createdAt])
  @@map("registros_temperatura")
}

model EquipoIntervencion {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  equipoId     String   @map("equipo_id") @db.Uuid
  tipo         String   @db.VarChar(50) // LIMPIEZA | SERVICE | REPARACION
  descripcion  String?
  costo        Decimal? @db.Decimal(10, 2)
  proveedor    String?
  usuarioId    String?  @map("usuario_id") @db.Uuid
  realizadoEn  DateTime @default(now()) @map("realizado_en")
  createdAt    DateTime @default(now()) @map("created_at")

  equipo Equipo @relation(fields: [equipoId], references: [id])

  @@index([tenantId, equipoId])
  @@map("equipo_intervenciones")
}

// --- 2.16 Feedback de calidad ---
model Feedback {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  sucursalId String   @map("sucursal_id") @db.Uuid
  pedidoId   String?  @map("pedido_id") @db.Uuid
  mesaId     String?  @map("mesa_id") @db.Uuid
  calificacion String @db.VarChar(20) // FELIZ | NEUTRAL | TRISTE
  motivo     String?
  turnoId    String?  @map("turno_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  pedido Pedido? @relation(fields: [pedidoId], references: [id])

  @@index([tenantId, sucursalId, calificacion])
  @@index([tenantId, createdAt])
  @@map("feedbacks")
}

// --- 2.19/2.20 Promociones y reglas de combo ---
model Promocion {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  nombre      String   @db.VarChar(100)
  descripcion String?
  tipo        String   @db.VarChar(50) // COMBO | DESCUENTO | 2X1
  condicion   Json     @default("{}") // reglas (ej. 2 pizzas grandes)
  descuento   Json     @default("{}") // acción (ej. bebida 50%)
  diaInicio   DateTime? @map("dia_inicio")
  diaFin      DateTime? @map("dia_fin")
  horaInicio  DateTime? @map("hora_inicio") @db.Time
  horaFin     DateTime? @map("hora_fin") @db.Time
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId, activa])
  @@map("promociones")
}

// --- 2.23 Módulos / licencias por tenant ---
model Modulo {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  clave       String   @db.VarChar(50) // DELIVERY | MULTISUCURSAL | PROVEEDORES
  nombre      String   @db.VarChar(100)
  activo      Boolean  @default(false)
  limite      Int?     // ej. nº de sucursales permitidas
  activadoEn  DateTime? @map("activado_en")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, clave])
  @@index([tenantId])
  @@map("modulos")
}
